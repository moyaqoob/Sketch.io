{
  "name": "Sketch.io-backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/server.ts",
    "start:backend": "bun run src/server.ts",
    "build": "bun build src/server.ts --target=bun --outdir dist",
    "deploy": "wrangler deploy --config ../../wrangler.backend.jsonc",
    "dev:cf": "wrangler dev --config ../../wrangler.backend.jsonc"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260415.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "latest",
    "wrangler": "^4.83.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@mswjs/interceptors": "^0.39.4",
    "@repo/backend-common": "workspace:*",
    "@repo/database": "workspace:*",
    "@repo/types": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "aws-sdk": "^2.1692.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "hono": "^4.7.4",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mock-aws-s3": "^4.0.2",
    "nock": "^14.0.6"
  }
}
